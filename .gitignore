# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.production.example

# deploy secrets (local only)
secrets.local.json
deploy-credentials.local.json
deploy/siteground-browser-session.json
deploy/siteground-browser-session.full.json
deploy/chrome-siteground-profile/

# local diagnostics / probes (may contain emails, IPs)
/reports/
/tmp-*.json
tmp-*.png
dev-server.log

# build / deploy artifacts (regenerate locally)
/deploy/*.zip
/deploy/siteground-upload/
/scripts/subdomain/bin/
/scripts/subdomain/*.log

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
