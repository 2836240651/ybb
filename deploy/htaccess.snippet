# Apache / SiteGround: merged BEFORE # BEGIN WordPress (WP catch-all stays last).
# Upload to public_html/.htaccess AFTER backing up the current file.
#
# Priority:
# 1. Static clean URLs → .html (before legacy export directories short-circuit rewrites)
# 2. WordPress admin, API, uploads, WooCommerce checkout paths
# 3. Next.js static assets (_next, images, products, etc.)
# 4. Existing files
# 5. Next.js HTML fallback for client routes

<IfModule mod_rewrite.c>
RewriteEngine On
RewriteBase /

# Nested products/{handle}/ dirs (legacy reviews export) must not trigger DirectorySlash 301 loops.
DirectorySlash Off

# --- Static clean URLs → .html (must run before directory pass-through) ---
# Legacy Next export may leave collections/{handle}/, products/{handle}/, blogs/news/{slug}/ dirs on disk.
# If those match RewriteCond -d first, WordPress catches the request and redirect_canonical loops.
RewriteRule ^blogs/([^/.]+)/([^/.]+)/?$ /blogs/$1/$2.html [R=301,L]
RewriteRule ^blogs/([^/.]+)/?$ /blogs/$1.html [R=301,L]
RewriteRule ^pages/([^/.]+)/?$ /pages/$1.html [R=301,L]
RewriteRule ^collections/([^/.]+)/?$ /collections/$1.html [R=301,L]
# --- Legacy Woo slug → handle (EARLY: before clean URL .html) ---
RewriteRule ^products/carp-accessory-orange-hook-needle-box-set/?$ /products/tz-zbsb-055 [R=301,L]
RewriteRule ^products/carp-accessory-orange-hook-needle-box-set\.html$ /products/tz-zbsb-055.html [R=301,L]
