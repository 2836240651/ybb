RewriteRule ^products/([^/.]+)/?$ /products/$1.html [R=301,L]

# --- Cache safety: prevent homepage split-cache variants ---
# Some cache layers treat `/?x=y` differently than `/` and can serve mismatched HTML/CSS bundles.
<IfModule mod_headers.c>
  SetEnvIf Request_URI "^/$" YBB_NO_CACHE=1
  SetEnvIf Request_URI "^/index\\.html$" YBB_NO_CACHE=1
  SetEnvIf Request_URI "^/collections(/|$)" YBB_NO_CACHE=1
  Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0" env=YBB_NO_CACHE
  Header set Pragma "no-cache" env=YBB_NO_CACHE
</IfModule>

# Pass through existing files only (legacy export directories must not short-circuit clean URLs).
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# --- WordPress + WooCommerce (keep backend alive) ---
# SiteGround may block bare /wp-admin/ (403 / SG-Captcha blank page). Canonicalize to index.php.
RewriteRule ^wp-admin/?$ /wp-admin/index.php [R=302,L]
RewriteRule ^wp-admin/index\.phpload-styles\.php$ /wp-admin/load-styles.php [QSA,L]
RewriteRule ^wp-admin/index\.phpload-scripts\.php$ /wp-admin/load-scripts.php [QSA,L]
RewriteRule ^wp-admin/load-styles\.php$ - [L]
RewriteRule ^wp-admin/load-scripts\.php$ - [L]
RewriteRule ^wp-admin/admin-ajax\.php$ - [L]
RewriteRule ^wp-admin/async-upload\.php$ - [L]
RewriteRule ^wp-admin/.*\.php$ - [L]
RewriteRule ^wp-admin/.+ - [L]
RewriteRule ^wp-login\.php$ - [L]
RewriteRule ^wp-cron\.php$ - [L]
RewriteRule ^wp-json(/.*)?$ /index.php [QSA,L]
RewriteRule ^embed/product-reviews/([0-9]+)/?$ /index.php?ybb_product_reviews_embed=$1 [L,QSA]
RewriteRule ^wp-content(/.*)?$ - [L]
RewriteRule ^wp-includes(/.*)?$ - [L]
RewriteRule ^xmlrpc\.php$ - [L]

# WooCommerce routes (phase 2 — cart / checkout / account stay on WP)
RewriteRule ^cart(/.*)?$ /index.php [QSA,L]
RewriteRule ^checkout(/.*)?$ /index.php [QSA,L]
RewriteRule ^airwallex-checkout(/.*)?$ /index.php [QSA,L]
RewriteRule ^my-account(/.*)?$ /index.php [QSA,L]
RewriteRule ^my-account-2(/.*)?$ /index.php [QSA,L]
RewriteRule ^wc-api(/.*)?$ /index.php [QSA,L]

# WooCommerce ?wc-ajax= on site root (cart fragments, checkout order review)
# Only /^?wc-ajax=/ — /checkout/?wc-ajax= is already handled by checkout rewrite above.
RewriteCond %{QUERY_STRING} (^|&)wc-ajax= [NC]
