# --- End legacy permalink redirects ---

# Legacy product URLs → new catalog (adjust after SKU mapping)
RewriteRule ^product/(.*)$ /products/$1 [R=301,L]

# Deprecated nested reviews path → flat reviews route (avoids products/{handle}/ directory vs .html conflict)
RewriteRule ^products/([^/.]+)/reviews/?$ /products/reviews/$1 [R=301,L]

# Wholesale alias → full catalog (static export has no /collections/wholesale page)
RewriteRule ^collections/wholesale/?$ /collections/all [R=301,L]
RewriteRule ^collections/wholesale\.html$ /collections/all.html [R=301,L]

# Next.js RSC payloads (*.txt): only for client router (Accept: text/x-component).
# Redirect accidental browser navigation to the HTML page (prevents /collections/all.txt in URL bar).
RewriteCond %{REQUEST_URI} \.txt$
RewriteCond %{REQUEST_URI} !^/robots\.txt$
RewriteCond %{HTTP_ACCEPT} !text/x-component
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^(.+)\.txt$ /$1.html [R=302,L]

# --- Next.js static assets ---
RewriteRule ^_next/ - [L]
RewriteRule ^images/ - [L]
RewriteRule ^favicon\.ico$ - [L]
RewriteRule ^robots\.txt$ - [L]
RewriteRule ^sitemap\.xml$ - [L]

# Force homepage to static export index to avoid root/index split cache variants.
RewriteRule ^$ /index.html [L]

# Prefer flat .html over legacy export directories (collections/, blogs/news/, etc.)
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+?)/?$ $1.html [L]

# Real files (directories intentionally excluded at top — see clean URL rules)
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Fallback to homepage for unknown routes (optional; comment out if you prefer 404.html)
RewriteRule ^ index.html [L]
</IfModule>
