{
  "name": "shopify-listing-playwright",
  "private": true,
  "type": "module",
  "scripts": {
    "open-chrome": "node 0-open-chrome.mjs",
    "capture": "node 1-capture-session.mjs",
    "import:products": "node 2-import-products.mjs",
    "import:inventory": "node 3-import-inventory.mjs",
    "import:all": "node 2-import-products.mjs && node 3-import-inventory.mjs",
    "import:batches": "node 4-import-batches.mjs",
    "upload:files": "node 6-upload-files.mjs",
    "scrape:files": "node 7-scrape-files-map.mjs",
    "assign:collection": "node 5-assign-collection.mjs",
    "assign:collections": "node 11-assign-collections-gql.mjs",
